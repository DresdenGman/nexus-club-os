{
  "entities": {
    "User": {
      "title": "User",
      "description": "A user of the platform (admin, club president, or member)",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "name": { "type": "string", "description": "User's full name" },
        "email": { "type": "string", "format": "email", "description": "User's email address" },
        "role": { "type": "string", "enum": ["admin", "president", "member"], "description": "User's role in the system" },
        "department": { "type": "string", "description": "User's academic department" },
        "joinDate": { "type": "string", "format": "date-time", "description": "When the user joined" },
        "contribution": { "type": "number", "description": "Contribution points" },
        "avatar": { "type": "string", "description": "URL to user's avatar" }
      },
      "required": ["uid", "name", "email", "role"]
    },
    "Club": {
      "title": "Club",
      "description": "A student club or organization",
      "type": "object",
      "properties": {
        "name": { "type": "string", "description": "Name of the club" },
        "type": { "type": "string", "description": "Category of the club (e.g., Tech, Arts)" },
        "membersCount": { "type": "number", "description": "Number of active members" },
        "status": { "type": "string", "enum": ["Active", "Pending", "Inactive"], "description": "Current status of the club" },
        "image": { "type": "string", "description": "URL to club's cover image" },
        "description": { "type": "string", "description": "Detailed description of the club" },
        "presidentId": { "type": "string", "description": "UID of the club president" }
      },
      "required": ["name", "type", "status", "presidentId"]
    },
    "Approval": {
      "title": "Approval",
      "description": "A request pending administrative approval",
      "type": "object",
      "properties": {
        "type": { "type": "string", "enum": ["Club Registration", "Venue Booking", "Budget Request"], "description": "Type of request" },
        "applicantId": { "type": "string", "description": "UID of the user who submitted the request" },
        "applicantName": { "type": "string", "description": "Name of the applicant" },
        "date": { "type": "string", "format": "date-time", "description": "Submission date" },
        "status": { "type": "string", "enum": ["Pending Review", "Approved", "Rejected"], "description": "Current status of the request" },
        "details": { "type": "string", "description": "Additional details or JSON payload of the request" }
      },
      "required": ["type", "applicantId", "applicantName", "date", "status"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "Stores user profiles and roles"
    },
    "/clubs/{clubId}": {
      "schema": { "$ref": "#/entities/Club" },
      "description": "Stores club information"
    },
    "/approvals/{approvalId}": {
      "schema": { "$ref": "#/entities/Approval" },
      "description": "Stores pending and resolved approval requests"
    }
  }
}
